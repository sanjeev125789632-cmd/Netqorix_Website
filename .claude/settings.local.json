{
  "permissions": {
    "allow": [
      "Skill(run)",
      "Skill(run:*)",
      "PowerShell(Get-Command chromium-cli -ErrorAction SilentlyContinue)",
      "PowerShell(Get-Command python -ErrorAction SilentlyContinue)",
      "PowerShell(Get-Command py -ErrorAction SilentlyContinue)",
      "PowerShell(Get-Command node -ErrorAction SilentlyContinue)",
      "PowerShell(Get-Command npx -ErrorAction SilentlyContinue)",
      "PowerShell(npx --yes playwright --version 2>&1)",
      "PowerShell($env:USERPROFILE; Test-Path \"$env:LOCALAPPDATA\\\\ms-playwright\"; if \\(Test-Path \"$env:LOCALAPPDATA\\\\ms-playwright\"\\) { Get-ChildItem \"$env:LOCALAPPDATA\\\\ms-playwright\" })"
    ]
  }
}
